<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="78dp"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/searchResultImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_album_cover"
        android:clipToOutline="true"
        android:importantForAccessibility="no"
android:scaleType="centerCrop"
        android:src="@drawable/ic_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/searchResultTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="@color/weather_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/searchResultSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:textColor="@color/album_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/searchResultMore"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_more"
        android:padding="8dp"
        android:src="@drawable/ic_more_horiz_24"
        android:tint="@color/weather_ink" />
</LinearLayout>
