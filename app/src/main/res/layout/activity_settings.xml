<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".SettingsActivity">

    <View
        android:id="@+id/settingsDimView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_settings_dim" />

    <com.skyshelf.app.SettingsSheetScrollView
        android:id="@+id/settingsSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_settings_sheet"
        android:clipToOutline="true"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="22dp">

        <FrameLayout
            android:id="@+id/settingsPanelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/settingsHomePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/account_sheet_title"
                        android:textColor="@color/weather_ink"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/settingsCloseButton"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_settings_close"
                        android:contentDescription="@string/cd_close_settings"
                        android:padding="14dp"
                        android:src="@drawable/ic_close_24"
                        android:tint="@color/weather_ink" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsGuestAuthPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/settingsLoginRow"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:background="@drawable/bg_settings_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/action_login"
                            android:textColor="@color/weather_ink"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right_24"
                            android:tint="@color/album_text_secondary"                             android:importantForAccessibility="no"
/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsLoginEditorRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_settings_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/settingsGuestLoginUsernameInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:autofillHints="username"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_username"
                            android:inputType="textPersonName"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/settingsGuestLoginPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:autofillHints="password"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_password"
                            android:inputType="textPassword"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/settingsGuestLoginButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_settings_primary_button"
                            android:gravity="center"
                            android:text="@string/action_login"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsSignupRow"
                        android:layout_width="match_parent"
                        android:layout_height="62dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_settings_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/action_signup"
                            android:textColor="@color/weather_ink"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_chevron_right_24"
                            android:tint="@color/album_text_secondary"                             android:importantForAccessibility="no"
/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsSignupEditorRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_settings_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/settingsGuestSignupUsernameInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:autofillHints="username"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_choose_username"
                            android:inputType="textPersonName"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/settingsGuestSignupPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:autofillHints="newPassword"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_choose_password"
                            android:inputType="textPassword"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/settingsGuestSignupButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_settings_primary_button"
                            android:gravity="center"
                            android:text="@string/action_create_account_title"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsProfileTile"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_settings_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="16dp">

                    <FrameLayout
                        android:id="@+id/settingsAvatarFrame"
                        android:layout_width="58dp"
                        android:layout_height="58dp">

                        <ImageView
                            android:id="@+id/settingsAvatarImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_settings_profile_circle"
                            android:clipToOutline="true"
                android:contentDescription="@string/cd_profile_photo"
android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/settingsAvatarText"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_settings_profile_circle"
                            android:gravity="center"
                            android:text="@string/profile_initial_guest"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/accountStatusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/guest"
                            android:textColor="@color/weather_ink"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/accountSubtitleText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/account_subtitle"
                            android:textColor="@color/album_text_secondary"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right_24"
                        android:tint="@color/album_text_secondary"                         android:importantForAccessibility="no"
/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsEmailButton"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_settings_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/account_change_email"
                        android:textColor="@color/weather_ink"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_verification_needed"
                        android:textColor="@color/album_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsPhoneButton"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_settings_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/account_change_phone"
                        android:textColor="@color/weather_ink"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_verification_needed"
                        android:textColor="@color/album_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsNotificationRow"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_settings_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/account_notifications"
                        android:textColor="@color/weather_ink"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right_24"
                        android:tint="@color/album_text_secondary"                         android:importantForAccessibility="no"
/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsPrivacyRow"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_settings_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/account_privacy_access"
                        android:textColor="@color/weather_ink"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right_24"
                        android:tint="@color/album_text_secondary"                         android:importantForAccessibility="no"
/>
                </LinearLayout>

                <TextView
                    android:id="@+id/settingsLogoutButton"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_settings_secondary_button"
                    android:gravity="center"
                    android:text="@string/action_log_out"
                    android:textColor="@color/danger"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsAccountPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/settingsAccountBackButton"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_settings_close"
                        android:contentDescription="@string/cd_back"
                        android:padding="14dp"
                        android:src="@drawable/ic_back_24"
                        android:tint="@color/weather_ink" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="@string/account_info_title"
                        android:textColor="@color/weather_ink"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/settingsAccountAvatarFrame"
                    android:layout_width="142dp"
                    android:layout_height="142dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/settingsAccountAvatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_settings_profile_circle"
                        android:clipToOutline="true"
                android:contentDescription="@string/cd_profile_photo"
android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/settingsAccountAvatarText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_settings_profile_circle"
                        android:gravity="center"
                        android:text="@string/profile_initial_guest"
                        android:textColor="@color/white"
                        android:textSize="42sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/settingsPhotoRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/settingsDisplayNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/guest"
                        android:textColor="@color/weather_ink"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/settingsEditNameButton"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_settings_close"
                        android:contentDescription="@string/cd_edit_name"
                        android:padding="10dp"
                        android:src="@drawable/ic_edit_24"
                        android:tint="@color/weather_ink" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsNameEditorRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/settingsUsernameInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:autofillHints="username"
                        android:background="@drawable/bg_settings_input"
                        android:hint="@string/hint_username"
                        android:inputType="textPersonName"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/weather_ink"
                        android:textColorHint="@color/album_text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/settingsChangeUsernameButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_settings_primary_button"
                        android:gravity="center"
                        android:text="@string/action_save_name"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsPasswordCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_settings_card"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/account_password_title"
                            android:textColor="@color/weather_ink"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/settingsEditPasswordButton"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="@string/cd_edit_password"
                            android:padding="9dp"
                            android:src="@drawable/ic_more_horiz_24"
                            android:tint="@color/weather_ink" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/settingsPasswordEditorRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/settingsPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:autofillHints="password"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_current_password"
                            android:inputType="textPassword"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/settingsNewPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="10dp"
                            android:autofillHints="newPassword"
                            android:background="@drawable/bg_settings_input"
                            android:hint="@string/hint_new_password"
                            android:inputType="textPassword"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textColor="@color/weather_ink"
                            android:textColorHint="@color/album_text_secondary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/settingsChangePasswordButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_settings_primary_button"
                            android:gravity="center"
                            android:text="@string/action_save_password"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsGuestButtons"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>
    </com.skyshelf.app.SettingsSheetScrollView>
</FrameLayout>
